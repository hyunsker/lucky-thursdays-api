{
  "name": "lucky-thursdays",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:web": "vite --host",
    "dev:proxy": "node server/fortune-proxy.mjs",
    "dev:full": "concurrently --kill-others-on-fail \"npm run dev:proxy\" \"npm run dev:web\"",
    "lan": "node scripts/show-lan-url.mjs",
    "dev:granite": "granite dev",
    "build": "vite build",
    "build:ait": "ait build",
    "worker:secret": "npm run secret --prefix ./cloudflare-worker",
    "worker:deploy": "npm run deploy --prefix ./cloudflare-worker",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.4.1",
    "@toss/tds-mobile": "^2.3.0",
    "concurrently": "^9.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.1",
    "vite": "^6.0.3"
  }
}
